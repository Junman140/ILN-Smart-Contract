    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.7.0",
