{
  "name": "iln-smart-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Invoice Liquidity Network - Smart Contracts Monorepo",
  "workspaces": [
    "sdk",
    "cli",
    "indexer",
    "notifications"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "install-all": "npm install && turbo run install"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
