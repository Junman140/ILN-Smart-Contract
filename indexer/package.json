{
  "name": "@iln/indexer",
  "version": "0.1.0",
  "description": "REST API indexer for the Invoice Liquidity Network smart contracts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage node_modules/.cache"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
