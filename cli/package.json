{
  "name": "@iln/cli",
  "version": "0.1.0",
  "description": "CLI for the Invoice Liquidity Network",
  "bin": {
    "iln": "./dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:cli-e2e": "vitest run tests/e2e",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@iln/test-utils": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "execa": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
