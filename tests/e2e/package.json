{
  "name": "@iln/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.ts --runInBand",
    "test:e2e:watch": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.ts --runInBand --watch",
    "test:e2e:allure": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.ts --runInBand --reporters=default --reporters=jest-allure-reporter",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "jest-allure-reporter": "^1.2.3",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
